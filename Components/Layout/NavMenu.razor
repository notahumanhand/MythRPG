@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">MythRPG</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <AuthorizeView>
                <Authorized>
                    <p class="text-light">
                        Logged In: @context.User.Identity?.Name
                    </p>
                </Authorized>
                <NotAuthorized>
                    <p class="text-light">Logged Out</p>
                </NotAuthorized>
            </AuthorizeView>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
            <NavLink class="nav-link" href="/classes">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Classes
            </NavLink>
            <NavLink class="nav-link" href="/mythics">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Mythic Paths
            </NavLink>
            <NavLink class="nav-link" href="/traits">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Traits
            </NavLink>
            <NavLink class="nav-link" href="/spells">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Spells
            </NavLink>
            <AuthorizeView>
                <Authorized>
                    <div class="mt-auto px-3 pb-3">
                        <form method="post" action="/logout" data-enhance="false">
                            <button type="submit" class="btn btn-sm btn-outline-light w-100">Log Out</button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

