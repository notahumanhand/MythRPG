@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
@inject NavigationManager NavigationManager
@inject ILogger<ViewProfile> Logger
@page "/profile"
@rendermode InteractiveServer

<AuthorizeView>
    <Authorized>
        <h3>Profile: @context.User.Identity?.Name</h3>
        <img src="@(currentUser?.ProfilePictureUrl ?? PortraitsRef.Default)" width="100" />
    <div class="form-group">
        <label for="username">Change Username</label>
        <input type="text" id="username" @bind="newusername" class="form-control" />
        <button type="button" class="btn btn-success" @onclick="UpdateUsername">Save Username</button>
    </div>
    <div class="form-group">
        <p>Current theme: Default</p>
        <label for="theme">Select Profile Theme</label>
        <select id="theme">
            <option value="Default">Default</option>
            <option value="Bloodstains">Bloodstains</option>
            <option value="Eternity">Eternity</option>
            <option value="Flame">Flame</option>
            <option value="Gilded">Gilded</option>
            <option value="Ice Lichen">Ice Lichen</option>
            <option value="Marshlands">Marshlands</option>
            <option value="Righteous">Rightous</option>
            <option value="Savannah">Savannah</option>
            <option value="Whiteout">Whiteout</option>
            <option value="Wooded">Wooded</option>
        </select>
        <button type="button" class="btn btn-success" @onclick="UpdateTheme">Save Theme</button>
    </div>
    <div class="form-group">
        <label>Select Profile Picture</label>
        <select class="form-control" @bind="selectedPortrait">
            @foreach (var p in portraits) 
            {
                <option value="@p.Url">@p.Name</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(selectedPortrait)) 
        {
            <img src="@selectedPortrait" width="100" class="mt-2" />
        }
        <button class="btn btn-success" @onclick="UpdateProfilePicture">Save Profile Picture</button>
    </div>
    </Authorized>
</AuthorizeView>

@code {
    private readonly List<(string Name, string Url)> portraits = PortraitsRef.All;
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }
    private User? currentUser;
    private string newusername = "";
    private string? selectedPortrait;
    protected override async Task OnInitializedAsync() {
        var authState = await AuthState;
        var userPrincipal = authState.User;

        if (userPrincipal.Identity?.IsAuthenticated == true) 
        {
            currentUser = await UserManager.GetUserAsync(userPrincipal);

            if (currentUser != null) {
                selectedPortrait = currentUser.ProfilePictureUrl ?? PortraitsRef.Default;
            }
        }
    }
    private async Task UpdateUsername()
    {
        var authState = await AuthState;
        var userPrincipal = authState.User;

        if (userPrincipal.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(userPrincipal);

            if (user != null && !string.IsNullOrWhiteSpace(newusername))
            {
                var oldUsername = user.UserName;

                user.UserName = newusername;
                await UserManager.UpdateAsync(user);

                Logger.LogInformation("USER_ACTION: User {OldUsername} changed username to {NewUsername}", oldUsername, newusername);

                newusername = "";
            }
        }
    }
    private void UpdateTheme()
    {

    }
    private async Task UpdateProfilePicture() 
    {
        var authState = await AuthState;
        var userPrincipal = authState.User;

        if (userPrincipal.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(userPrincipal);

            if (user != null && !string.IsNullOrEmpty(selectedPortrait))
            {
                user.ProfilePictureUrl = selectedPortrait;
                await UserManager.UpdateAsync(user);

                Logger.LogInformation("User {User} updated profile picture", user.UserName);

                currentUser = user;
            }
        }
    }
}
