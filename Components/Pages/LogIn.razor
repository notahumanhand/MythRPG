@inject Data.AppData AppData
@inject IUsersRepository UsersRepository
@inject NavigationManager NavigationManager;
@rendermode InteractiveServer
@page "/login"

<PageTitle>Mythmaven: Login</PageTitle>
<h1 class="align-content-center">Log In</h1>
<br />
<div class="form-group">
    <label for="username">Username</label>
    <input type="text" id="username" @bind="username" class="form-control"></input>
</div>
<div class="form-group">
    <label for="password">Password</label>
    <input type="text" id="password" @bind="password" class="form-control"></input>
</div>
<br />
<button type="button" class="btn btn-success" @onclick="TryLogin">Log In</button>
@if (failedlogin) 
{
    <p class="alert alert-danger">Login failed! Please try again. <button type="button" class="btn btn-danger" @onclick="ClearAlert">X</button></p>
}

@code {
    private string username = "";
    private string password = "";
    private bool failedlogin = false;
    private void TryLogin()
    {
        User? user = UsersRepository.LogIn(username, password);
        if (user is not null)
        {
            AppData.user = user;
            NavigationManager.NavigateTo("/");
        }
        else
        {
            failedlogin = true;
            username = "";
            password = "";
        }
    }
    void ClearAlert()
    {
        failedlogin = false;
    }
}