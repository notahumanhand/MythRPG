@using Microsoft.AspNetCore.Identity
@inject NavigationManager NavigationManager;
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@page "/login"

<PageTitle>Mythmaven: Login</PageTitle>
<h1 class="align-content-center">Log In</h1>
<br />
<form method="post" action="/login-post" data-enhance="false">
    <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" class="form-control">
    </div>
    <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control">
    </div>
    <br />
    <button type="submit" class="btn btn-success">Log In</button>
</form>
@if (NavigationManager.Uri.Contains("error=true")) 
{
    <p class="alert alert-danger">Login failed! Please try again.</p>
}

